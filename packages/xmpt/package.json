{
  "name": "@lucid-agents/xmpt",
  "version": "0.1.0",
  "description": "Agent-to-agent messaging extension for the Lucid SDK",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
