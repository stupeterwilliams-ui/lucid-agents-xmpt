{
  "name": "@lucid-agents/xmpt",
  "version": "0.1.0",
  "description": "Agent-to-agent messaging extension for the Lucid SDK",
  "repository": {
    "type": "git",
    "url": "https://github.com/stupeterwilliams-ui/lucid-agents-xmpt",
    "directory": "packages/xmpt"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "bun test src/__tests__"
  },
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "@types/bun": "latest"
  },
  "keywords": [
    "lucid-agents",
    "agent-to-agent",
    "messaging",
    "xmpt",
    "a2a",
    "ai-agents"
  ],
  "license": "MIT"
}
