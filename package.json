{
  "name": "@lucid-agents/xmpt",
  "version": "0.1.0",
  "description": "Agent-to-agent messaging extension for Lucid SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "example": "bun run examples/local-messaging.ts"
  },
  "dependencies": {
    "@lucid-agents/a2a": "^0.6.2",
    "@lucid-agents/core": "^2.5.0",
    "@lucid-agents/http": "^1.10.2",
    "@lucid-agents/types": "^1.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stupeterwilliams-ui/lucid-agents-xmpt.git"
  },
  "keywords": [
    "lucid-agents",
    "xmpt",
    "agent-to-agent",
    "messaging",
    "a2a",
    "extension"
  ],
  "author": "Lucid Agents",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
